# ==============================================================================
# DocVision — Environment Configuration
# Copy this file to `.env` and fill in the values.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME=DocVision
APP_ENV=development                 # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
CORS_ORIGINS=*                      # comma-separated list or *

# ------------------------------------------------------------------------------
# PostgreSQL + PGVector
# ------------------------------------------------------------------------------
# Option A (recommended): a single hosted connection string, e.g. from Neon
# (neon.tech has a free tier with pgvector built in). Use the DIRECT/unpooled
# host (no "-pooler" in the hostname) — our app manages its own connection pool.
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# Option B: discrete fields, used only if DATABASE_URL is not set (e.g. local
# Docker Compose Postgres).
POSTGRES_USER=docvision
POSTGRES_PASSWORD=docvision
POSTGRES_DB=docvision
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_ECHO=false

# ------------------------------------------------------------------------------
# Google Gemini
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_VISION_MODEL=gemini-3.1-flash-lite
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536           # gemini-embedding-001 output dimensionality (768 | 1536 | 3072)
GEMINI_MAX_RETRIES=4
GEMINI_TEMPERATURE=0.2

# ------------------------------------------------------------------------------
# Cloudinary
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=docvision

# ------------------------------------------------------------------------------
# Ingestion / Chunking
# ------------------------------------------------------------------------------
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=120
CHUNK_MIN_TOKENS=64
MAX_UPLOAD_SIZE_MB=50
MIN_IMAGE_WIDTH=48                  # skip tiny decorative images (px)
MIN_IMAGE_HEIGHT=48

# ------------------------------------------------------------------------------
# Retrieval / Chat
# ------------------------------------------------------------------------------
RETRIEVAL_TOP_K=6
RETRIEVAL_MIN_SCORE=0.20            # cosine-similarity floor for returned chunks
MAX_IMAGES_PER_ANSWER=6
